# Copy to .env for local overrides (or set these directly in your deploy
# platform's environment-variable settings). All have sane defaults except
# the checkpoint path/URL in a fresh deployment — see README.md.

# Path to the trained checkpoint (best.pt). Defaults to
# ../ml/runs/rawnet2_codecaug/best.pt, which only exists if you've run the
# ml/ training pipeline locally. On a fresh deploy this file won't be
# present — either set this to a path on a mounted persistent disk, or
# leave the default and set MODEL_CHECKPOINT_URL below so it's fetched
# automatically on first startup.
MODEL_CHECKPOINT_PATH=

# If MODEL_CHECKPOINT_PATH doesn't exist at startup, the server will
# download it from this URL (any direct-HTTPS link: a private storage
# bucket's signed URL, a GitHub Release asset, a Hugging Face Hub file
# URL, etc.) and cache it at MODEL_CHECKPOINT_PATH for next time. See
# README.md "Deploying the checkpoint" for options and trade-offs.
# Default checkpoint (rawnet2_codecaug/best.pt), public HF model repo:
MODEL_CHECKPOINT_URL=https://huggingface.co/Arya12367/voicefence-rawnet2-codecaug/resolve/main/best.pt

# SHA-256 of the file MODEL_CHECKPOINT_URL points to. If set, the server
# verifies the download against this hash after fetching and refuses to
# load it (crashing startup loudly) on a mismatch — catches a corrupt
# transfer or a URL silently pointed at the wrong file. Recompute if you
# ever replace the checkpoint at that URL.
MODEL_CHECKPOINT_SHA256=82af0aaa4de1d849e0f00d1ea4662c1ed774f539e7ef8f915006fe307d87be42

# "cuda" | "cpu" | unset (auto-detect; falls back to cpu if no GPU)
MODEL_DEVICE=

# Comma-separated allowed origins for the frontend, e.g.
# https://voicefence.vercel.app,https://staging.voicefence.vercel.app
# Defaults to * (any origin) — fine for early development, tighten before
# handling real traffic.
CORS_ORIGINS=*

# Reject uploads larger than this many megabytes (/analyze).
MAX_UPLOAD_MB=25

# /ws/live-analyze abuse protection (no auth yet — see README.md "Streaming
# endpoint" TODO). Max call length in seconds before the server ends it.
MAX_CALL_SECONDS=600

# /ws/live-analyze: close the connection if a single binary frame exceeds
# this many bytes. ~32KB is a real 1s/16kHz/16-bit chunk, so 1MB is generous
# headroom against abuse, not a normal-use ceiling.
MAX_WS_CHUNK_BYTES=1000000

# Port uvicorn binds to. Render sets this automatically — don't hardcode
# it in the Dockerfile's own environment for that platform.
PORT=8000
