# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
build/
dist/

# ML artifacts — never commit data or weights
# Anchored to ml/ specifically (not a bare "data/"/"runs/") — an unanchored
# pattern here previously also matched, and silently excluded from git, the
# real source subpackage ml/src/awaaz_ml/data/, breaking every fresh clone
# (ModuleNotFoundError: No module named 'awaaz_ml.data') while working fine
# locally since dev envs read straight off disk regardless of git tracking.
/ml/data/
/ml/datasets/
/ml/runs/
*.pt
*.pth
*.onnx
*.flac
*.wav
*.mp3
*.ogg
*.amr
*.gsm
!ml/tests/fixtures/**

# Node (later phases)
node_modules/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.log

# Backend env files (secrets/local overrides) — .env.example stays tracked
backend/.env
.env

# Local test artifacts / screenshots
.test-shots/

# Personal Claude Code settings (machine-specific permissions)
.claude/settings.local.json
