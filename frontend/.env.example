# Base URL of the backend (see ../backend/README.md). No trailing slash.
# Local dev default matches `uvicorn app.main:app --port 8000` in backend/.
VITE_API_URL=http://127.0.0.1:8000

# Supabase project (Project Settings -> API in the Supabase dashboard).
# The anon key is safe to expose client-side — it's constrained by Row Level
# Security policies on each table, not a secret by itself.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
